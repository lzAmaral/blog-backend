# Servidor
PORT=3333
NODE_ENV=development

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=blog_db

# Autenticação
JWT_SECRET=troque-este-valor-por-um-segredo-forte
JWT_EXPIRES_IN=1d

# Upload de imagens
UPLOADS_DIR=uploads/banners
MAX_UPLOAD_SIZE_MB=5

# CORS
CORS_ORIGIN=http://localhost:5173
